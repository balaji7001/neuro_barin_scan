"use client";

import {
    LineChart,
    Line,
    XAxis,
    YAxis,
    Tooltip,
    ResponsiveContainer
    } from "recharts";

    const data = Array.from({ length: 20 }, (_, i) => ({
    time: i,
    value: Math.sin(i / 2) * 10
    }));

    export default function EEGGraph() {
    return (
        <div className="bg-white p-4 rounded-xl mt-4 shadow">

        <h3 className="text-green-600 mb-2">
            EEG Signal
        </h3>

        <ResponsiveContainer width="100%" height={200}>
            <LineChart data={data}>
            <XAxis dataKey="time" />
            <YAxis />
            <Tooltip />
            <Line dataKey="value" stroke="#2ECC71" />
            </LineChart>
        </ResponsiveContainer>

        </div>
    );
}